{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/preferences",
      "dest": "/preferences.html"
    },
    {
      "src": "/digest",
      "dest": "/digest.html"
    },
    {
      "src": "/kodnest-demo",
      "dest": "/kodnest-demo.html"
    }
  ]
}
